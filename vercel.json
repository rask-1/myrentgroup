{
  "version": 2,
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/lead",
      "destination": "/api/lead.js"
    },
    {
      "source": "/api/telegram-bot",
      "destination": "/api/telegram-bot.js"
    },
    {
      "source": "/policy",
      "destination": "/client/policy/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/client/$1"
    }
  ]
}